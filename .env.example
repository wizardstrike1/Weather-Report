# Copy to .env and fill in. The .env file is git-ignored and never sent anywhere
# except as the Authorization header to the Anthropic API.

# Optional. Without it the app falls back to the Claude Code CLI (`claude -p`)
# if installed/logged-in, then to manual mode. Set it for direct API use.
ANTHROPIC_API_KEY=

# Command used for the CLI fallback (must be on PATH and authenticated).
CTF_COPILOT_CLAUDE_CLI=claude

# Optional overrides (otherwise configured via Settings UI / config.json)
CTF_COPILOT_MODEL=claude-opus-4-7
CTF_COPILOT_MAX_TOKENS_PER_STEP=2048
CTF_COPILOT_PROJECTS_DIR=
